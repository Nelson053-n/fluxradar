# Скопируй в .env и заполни. Файл .env в репозиторий НЕ коммитится (§9 ТЗ).

# --- PostgreSQL (совпадает с дефолтами infra/docker-compose.yml) ---
# Порты смещены (5434/6381), чтобы не конфликтовать со стандартными 5432/6379.
POSTGRES_USER=fluxscope
POSTGRES_PASSWORD=fluxscope
POSTGRES_DB=fluxscope
DATABASE_URL=postgres://fluxscope:fluxscope@localhost:5434/fluxscope

# --- Redis ---
REDIS_URL=redis://localhost:6381

# --- API ---
API_BIND=0.0.0.0:5049

# --- Telegram-бот ---
# Получить через @BotFather. Только здесь, никогда в коде/репозитории (§9).
TELEGRAM_BOT_TOKEN=PUT_YOUR_BOT_TOKEN_HERE

# --- Логи ---
RUST_LOG=info
